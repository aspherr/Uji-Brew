generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Product {
  id          String   @id @default(uuid())
  name        String
  desc        String?
  price       Int
  imageUrl    String?
  stock       Int
  isAvailable Boolean
  createdAt   DateTime @default(now())

  orderItems OrderItem[]
}

model Order {
  id         String      @id @default(uuid())
  authUserId String      @db.Uuid
  total      Int
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  items    OrderItem[]
  payments Payment[]

  @@index([authUserId])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Int
  status    String
  provider  String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Address {
  id         String @id @default(uuid())
  authUserId String @db.Uuid
  line1      String
  line2      String?
  city       String
  postcode   String
  country    String

  @@index([authUserId])
}